# API Server URL
# For local development, this defaults to http://localhost:8000
# For production, set this to your actual API server URL
# Example: VITE_API_URL=https://api.gpushare.example.com
VITE_API_URL=http://localhost:8000

# Stripe Publishable Key
# Get this from your Stripe Dashboard
# Example: VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=
